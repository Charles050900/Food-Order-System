        <dc:Bounds x="320" y="840" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0cnou3r_di" bpmnElement="Event_0cnou3r">
        <dc:Bounds x="502" y="682" width="36" height="36" />
